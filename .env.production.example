# ═══════════════════════════════════════════════
# CloudLab Production Environment
# Copy to .env.production and fill in values
# ═══════════════════════════════════════════════

# ─── Server ───
PORT=3000
NODE_ENV=production
BASE_DOMAIN=labs.yourdomain.com
PUBLIC_HOST=136.113.181.196

# ─── Database ───
POSTGRES_DB=labdb
POSTGRES_USER=labuser
POSTGRES_PASSWORD=CHANGE_ME_DB_PASS

# ─── Auth ───
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_ACCESS_EXPIRES=900
JWT_REFRESH_EXPIRES=604800

# ─── Firebase (optional — for frontend auth) ───
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_ADMIN_CLIENT_EMAIL=your-sa@project.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Frontend ───
FRONTEND_URL=http://136.113.181.196

# ─── Docker / Labs ───
DOCKER_SOCKET=/var/run/docker.sock
CONTAINER_NETWORK=lab-network
CONTAINER_CPU_LIMIT=0.5
CONTAINER_MEMORY_LIMIT=536870912
MAX_ACTIVE_SESSIONS_PER_USER=3
MAX_TOTAL_ACTIVE_CONTAINERS=20
DEFAULT_SESSION_TTL=3600
KEEP_RECENT_SESSIONS=3
LAB_DATA_DIR=/app/lab-data
