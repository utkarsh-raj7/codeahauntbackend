# ═══════════════════════════════════════════════
# CloudLab — Production Environment
# ═══════════════════════════════════════════════

# Server
NODE_ENV=production
PORT=3000
BASE_DOMAIN=labs.yourdomain.com

# Database (matches docker-compose.prod.yml)
POSTGRES_DB=labdb
POSTGRES_USER=labuser
POSTGRES_PASSWORD=CHANGE_ME_DB_PASS

# Auth
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_ACCESS_EXPIRES=900
JWT_REFRESH_EXPIRES=604800

# Firebase (required for frontend auth)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Frontend
FRONTEND_URL=https://yourdomain.com

# Docker
CONTAINER_CPU_LIMIT=0.5
CONTAINER_MEMORY_LIMIT=536870912
MAX_ACTIVE_SESSIONS_PER_USER=3
MAX_TOTAL_ACTIVE_CONTAINERS=50
DEFAULT_SESSION_TTL=3600
KEEP_RECENT_SESSIONS=3

# Notifications (optional)
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=your-smtp-password
