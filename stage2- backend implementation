4.1  Token Refresh Job — Not Implemented
Embed tokens expire in 10 minutes. A BullMQ delayed job must re-issue them and push the new URL via WebSocket. Frontend updates iframe src on token_refresh event.

// src/jobs/tokenRefresh.job.ts — new file
tokenRefreshWorker.process(async (job) => {
  const { sessionId, userId } = job.data;
  const session = await getSession(sessionId);
  if (!session || session.status !== 'ready') return;
  const newToken = await authService.issueEmbedToken(sessionId, userId);
  const newUrl = `https://${session.subdomain}.${BASE_DOMAIN}/terminal?token=${newToken}`;
  await db.update(sessions).set({ terminalUrl: newUrl }).where(eq(sessions.id, sessionId));
  await publishEvent(sessionId, 'token_refresh', { terminal_url: newUrl });
});
 
// In provision.job.ts — add after session goes ready:
await tokenRefreshQueue.add('refresh-embed-token', { sessionId, userId },
  { delay: 9*60*1000, repeat: { every: 9*60*1000 } });

4.2  gateway.ts — Verify Time Warning and Cleanup
// Confirm this pattern exists and clearInterval fires on close
const warningInterval = setInterval(async () => {
  const ttl = await redisClient.ttl(`sess:${sessionId}`);
  if (ttl > 0 && ttl <= 300) {
    publishEvent(sessionId, 'time_warning', { minutes_remaining: Math.ceil(ttl/60) });
  }
  if (ttl <= 0) {
    publishEvent(sessionId, 'session_expired', { reason: 'ttl_reached' });
    socket.close(1000, 'Session expired');
  }
}, 30000);
 
socket.on('close', () => {
  clearInterval(warningInterval);   // MUST exist — memory leak if missing
  subscriber.unsubscribe(channel);
  subscriber.quit();
});

