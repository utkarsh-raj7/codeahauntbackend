# Server
PORT=3000
NODE_ENV=development
BASE_DOMAIN=labs.yourdomain.com

# Database
DATABASE_URL=postgresql://labuser:devpassword@localhost:5432/labdb
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-256-bit-secret-here
JWT_ACCESS_EXPIRES=900
JWT_REFRESH_EXPIRES=604800
LAB_TOKEN_EXPIRES=600
JWT_EMBED_SECRET=your-embed-secret-here

# Firebase Auth (frontend uses Firebase — backend verifies tokens)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Frontend
FRONTEND_URL=http://localhost:3000

# Docker
DOCKER_SOCKET=/var/run/docker.sock
CONTAINER_NETWORK=lab-network
CONTAINER_CPU_LIMIT=0.5
CONTAINER_MEMORY_LIMIT=536870912
MAX_ACTIVE_SESSIONS_PER_USER=2
DEFAULT_SESSION_TTL=3600
MAX_SESSION_TTL=14400

# Traefik
TRAEFIK_API_URL=http://traefik:8080

# Infra limits
MAX_TOTAL_ACTIVE_CONTAINERS=50
CLEANUP_INTERVAL_MS=60000
MONITOR_INTERVAL_MS=10000

# Notifications
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
